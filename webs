<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TAG REBORN</title>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Poppins',sans-serif;
scroll-behavior:smooth;
}

body{
background:#f7f7f7;
color:#333;
}

/* NAVBAR */

nav{
position:fixed;
top:0;
left:0;
width:100%;
padding:15px 8%;
background:rgba(0,0,0,.8);
backdrop-filter:blur(10px);
display:flex;
justify-content:space-between;
align-items:center;
z-index:1000;
}

.logo{
color:white;
font-size:24px;
font-weight:700;
}

nav ul{
display:flex;
gap:25px;
list-style:none;
}

nav a{
color:white;
text-decoration:none;
font-weight:500;
}

/* HERO */

.hero{
height:100vh;
background:
linear-gradient(rgba(0,0,0,.6),rgba(0,0,0,.6)),
url('space1.jpg');
background-size:cover;
background-position:center;
display:flex;
justify-content:center;
align-items:center;
text-align:center;
color:white;
padding:20px;
}

.hero-content h1{
font-size:70px;
margin-bottom:10px;
}

.hero-content p{
font-size:20px;
margin-bottom:30px;
}

.btn{
padding:14px 35px;
background:#c1121f;
color:white;
border:none;
border-radius:50px;
text-decoration:none;
font-weight:600;
}

/* SECTION */

section{
padding:100px 8%;
}

.title{
text-align:center;
font-size:40px;
margin-bottom:50px;
}

/* CARD */

.cards{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
gap:30px;
}

.card{
background:white;
border-radius:20px;
overflow:hidden;
box-shadow:0 10px 25px rgba(0,0,0,.1);
transition:.3s;
}

.card:hover{
transform:translateY(-10px);
}

.card img{
width:100%;
height:250px;
object-fit:cover;
}

.card-content{
padding:20px;
}

.card-content h3{
margin-bottom:10px;
}

.card-content p{
color:#666;
margin-bottom:15px;
}

.card button{
padding:12px 25px;
border:none;
background:#c1121f;
color:white;
border-radius:10px;
cursor:pointer;
}

/* LOCATION */

.location{
text-align:center;
}

.location img{
width:120px;
margin-bottom:20px;
}

.location button{
padding:15px 35px;
background:#c1121f;
border:none;
color:white;
border-radius:10px;
cursor:pointer;
}

/* FOOTER */

footer{
background:#111;
color:white;
text-align:center;
padding:40px 20px;
}

/* MODAL */

.modal{
display:none;
position:fixed;
top:0;
left:0;
width:100%;
height:100%;
background:rgba(0,0,0,.95);
justify-content:center;
align-items:center;
z-index:9999;
}

.modal-content{
position:relative;
display:flex;
align-items:center;
justify-content:center;
width:100%;
}

.modal-content img{
max-width:90%;
max-height:85vh;
border-radius:15px;
}

.close{
position:absolute;
top:20px;
right:30px;
font-size:50px;
color:white;
cursor:pointer;
}

.prev,
.next{
position:absolute;
top:50%;
transform:translateY(-50%);
width:60px;
height:60px;
border:none;
border-radius:50%;
font-size:25px;
cursor:pointer;
}

.prev{
left:20px;
}

.next{
right:20px;
}

@media(max-width:768px){

.hero-content h1{
font-size:45px;
}

nav ul{
display:none;
}

}

</style>
</head>
<body>

<nav>
<div class="logo">TAG REBORN</div>
<ul>
<li><a href="#menu">Menu</a></li>
<li><a href="#space">Space</a></li>
<li><a href="#location">Location</a></li>
</ul>
</nav>

<section class="hero">

<div class="hero-content">

<h1>TAG REBORN</h1>

<p>Taste A Good Reborn</p>

<a href="#menu" class="btn">Lihat Menu</a>

</div>

</section>

<section id="menu">

<h2 class="title">Menu Kami</h2>

<div class="cards">

<div class="card">

<img src="Menu_20260618_143201_0000.jpg">

<div class="card-content">

<h3>Drink & Food</h3>

<p>Berbagai pilihan makanan dan minuman terbaik.</p>

<button onclick="detail(0)">Lihat Detail</button>

</div>

</div>

</div>

</section>

<section id="space">

<h2 class="title">Space Available</h2>

<div class="cards">

<div class="card">

<img src="670823728_18325187719302079_8813370263803317540_n..jpg">

<div class="card-content">

<h3>Ruang Tersedia</h3>

<p>Tempat nyaman untuk nongkrong, meeting dan bersantai.</p>

<button onclick="detail(1)">Lihat Detail</button>

</div>

</div>

</div>

</section>

<section id="location">

<h2 class="title">Location</h2>

<div class="location">

<img src="https://cdn-icons-png.flaticon.com/512/684/684908.png">

<p style="margin-bottom:20px;">
Klik tombol di bawah untuk membuka lokasi TAG REBORN.
</p>

<button onclick="window.open('https://maps.app.goo.gl/dDCzSDV8AEF1NBd37')">
Buka Maps
</button>

</div>

</section>

<footer>

<h3>TAG REBORN</h3>

<p>Taste A Good Reborn</p>

</footer>

<div class="modal" id="modal">

<div class="modal-content">

<span class="close" onclick="tutup()">&times;</span>

<button class="prev" onclick="prevImage()">❮</button>

<img id="gambarBesar">

<button class="next" onclick="nextImage()">❯</button>

</div>

</div>

<script>

const produk = [

[
"Menu_20260618_143201_0000.jpg",
"Menu_20260618_143201_0001.jpg",
"Menu_20260618_143201_0002.jpg"
],

[
"670823728_18325187719302079_8813370263803317540_n..jpg",
"671204985_18325187833302079_6147699870994329688_n..jpg",
"671285066_18325187782302079_442439084785477968_n..jpg"
]

];

let currentProduk = 0;
let currentImage = 0;

function detail(index){

currentProduk = index;
currentImage = 0;

document.getElementById("gambarBesar").src =
produk[currentProduk][currentImage];

document.getElementById("modal").style.display = "flex";

}

function nextImage(){

currentImage++;

if(currentImage >= produk[currentProduk].length){
currentImage = 0;
}

document.getElementById("gambarBesar").src =
produk[currentProduk][currentImage];

}

function prevImage(){

currentImage--;

if(currentImage < 0){
currentImage = produk[currentProduk].length - 1;
}

document.getElementById("gambarBesar").src =
produk[currentProduk][currentImage];

}

function tutup(){
document.getElementById("modal").style.display = "none";
}

window.onclick = function(event){

const modal = document.getElementById("modal");

if(event.target == modal){
modal.style.display = "none";
}

}

</script>

</body>
</html>